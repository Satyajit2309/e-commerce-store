@page "/cart"
@attribute [Authorize]
@using EcommerceStore.Services.Interfaces
@using EcommerceStore.Models.Entities
@using Microsoft.AspNetCore.Authorization
@inject ICartService CartService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>Cart | Futurbol</PageTitle>

<style type="text/tailwindcss">
    :root { --alert-color: #0df20d; }

    .futurbol-page {
        background-color: #000000;
        color: #ffffff;
        font-family: 'Space Grotesk', sans-serif;
        background-image:
            linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
        background-size: 50px 50px;
    }

    .lab-readout {
        font-family: 'Space Grotesk', monospace;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .data-grid-border {
        border: 1px solid rgba(255,255,255,0.1);
        position: relative;
    }

    .data-grid-border::before {
        content: '';
        position: absolute;
        top: -2px; left: -2px;
        width: 10px; height: 10px;
        border-top: 2px solid var(--alert-color);
        border-left: 2px solid var(--alert-color);
    }

    .data-grid-border::after {
        content: '';
        position: absolute;
        bottom: -2px; right: -2px;
        width: 10px; height: 10px;
        border-bottom: 2px solid var(--alert-color);
        border-right: 2px solid var(--alert-color);
    }

    .qty-btn {
        width: 36px; height: 36px;
        display: flex; align-items: center; justify-content: center;
        border: 1px solid rgba(255,255,255,0.2);
        background: transparent; color: #fff;
        font-size: 18px; cursor: pointer;
        transition: all 0.2s ease;
    }

    .qty-btn:hover {
        border-color: var(--alert-color);
        color: var(--alert-color);
    }

    .qty-btn:disabled {
        opacity: 0.3;
        cursor: not-allowed;
    }

    .cart-item-row {
        border-bottom: 1px solid rgba(255,255,255,0.06);
        transition: background 0.2s ease;
    }

    .cart-item-row:hover {
        background: rgba(255,255,255,0.02);
    }

    .toast-msg {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        z-index: 100;
        padding: 1rem 1.5rem;
        font-size: 0.75rem;
        border: 1px solid rgba(13,242,13,0.3);
        background: rgba(0,0,0,0.95);
        backdrop-filter: blur(8px);
        animation: slideIn 0.3s ease-out;
    }

    .toast-error {
        border-color: rgba(239,68,68,0.4);
        color: #f87171;
    }

    .toast-success {
        border-color: rgba(13,242,13,0.3);
        color: #0df20d;
    }

    @@keyframes slideIn {
        from { transform: translateY(1rem); opacity: 0; }
        to   { transform: translateY(0); opacity: 1; }
    }
</style>

<div class="futurbol-page min-h-screen overflow-x-hidden">
    @* Navbar *@
    <nav class="fixed top-0 left-0 w-full z-50 border-b border-white/20 bg-black/80 backdrop-blur-md">
        <div class="flex items-center justify-between px-6 py-4">
            <div class="flex flex-col">
                <span class="text-xs text-alert lab-readout font-bold leading-none">Status: Active</span>
                <a href="/" class="text-2xl font-bold tracking-tighter uppercase no-underline text-white">Futurbol//Lab</a>
            </div>
            <div class="flex items-center gap-3">
                <a href="/catalog" class="text-[10px] lab-readout text-white/60 hover:text-alert transition-colors no-underline">Catalog</a>
                <AuthorizeView>
                    <Authorized Context="authState">
                        <a class="border border-white/30 px-4 py-2 text-[10px] lab-readout hover:bg-white hover:text-black transition-all no-underline text-white" href="/account/logout">Logout</a>
                        <AuthorizeView Roles="@EcommerceStore.Constants.Roles.Admin" Context="adminCtx">
                            <a class="border border-alert/40 px-4 py-2 text-[10px] lab-readout text-alert hover:bg-alert hover:text-black transition-all no-underline" href="/admin">Admin</a>
                        </AuthorizeView>
                    </Authorized>
                    <NotAuthorized>
                        <a class="border border-white/30 px-4 py-2 text-[10px] lab-readout hover:bg-white hover:text-black transition-all no-underline text-white" href="/account/login">Login</a>
                    </NotAuthorized>
                </AuthorizeView>
                <a href="/cart" class="border border-alert/40 px-4 py-2 text-[10px] lab-readout text-alert hover:bg-alert hover:text-black transition-all no-underline">
                    Cart (@_cartCount)
                </a>
            </div>
        </div>
    </nav>

    <main class="pt-28 pb-20 px-6 lg:px-20">
        @* Header *@
        <div class="mb-12">
            <div class="flex items-center gap-3 mb-3">
                <div class="w-2 h-2 bg-alert rounded-full animate-pulse"></div>
                <span class="text-[10px] lab-readout font-bold text-alert">Cart // Inventory</span>
            </div>
            <h1 class="text-5xl md:text-6xl font-bold uppercase tracking-tighter">Your Cart</h1>
        </div>

        @if (_loading)
        {
            <div class="flex items-center gap-3 text-white/40 text-sm lab-readout">
                <div class="w-2 h-2 bg-alert rounded-full animate-pulse"></div>Loading cart data...
            </div>
        }
        else if (!_cartItems.Any())
        {
            <div class="border border-white/10 p-16 text-center data-grid-border">
                <span class="material-symbols-outlined text-white/10 text-7xl block mb-6">shopping_cart</span>
                <div class="text-white/40 text-sm lab-readout mb-2">Cart is empty</div>
                <p class="text-white/20 text-xs lab-readout mb-8">No items in your inventory. Browse the catalog to add products.</p>
                <a href="/catalog"
                   class="border border-white/30 px-8 py-4 text-[10px] lab-readout font-bold hover:bg-white hover:text-black transition-all no-underline text-white inline-block">
                    Browse Catalog
                </a>
            </div>
        }
        else
        {
            @* Cart items table *@
            <div class="border border-white/10 bg-black/60 mb-8">
                @* Header row *@
                <div class="hidden md:grid grid-cols-12 gap-4 px-8 py-4 border-b border-white/10 text-[10px] lab-readout text-white/40 font-bold">
                    <div class="col-span-5">Product</div>
                    <div class="col-span-2 text-center">Unit Price</div>
                    <div class="col-span-2 text-center">Quantity</div>
                    <div class="col-span-2 text-right">Line Total</div>
                    <div class="col-span-1"></div>
                </div>

                @foreach (var item in _cartItems)
                {
                    <div class="cart-item-row grid grid-cols-1 md:grid-cols-12 gap-4 px-8 py-6 items-center">
                        @* Product info *@
                        <div class="md:col-span-5 flex items-center gap-4">
                            <div class="w-20 h-20 border border-white/10 flex-shrink-0 flex items-center justify-center bg-white/[0.02] overflow-hidden">
                                @if (!string.IsNullOrWhiteSpace(item.Product?.ImageUrl))
                                {
                                    <img alt="@item.Product.Name" class="w-full h-full object-contain grayscale" src="@item.Product.ImageUrl" />
                                }
                                else
                                {
                                    <span class="material-symbols-outlined text-white/10 text-3xl">checkroom</span>
                                }
                            </div>
                            <div>
                                <a href="/catalog/@item.ProductId" class="text-sm font-bold uppercase no-underline text-white hover:text-alert transition-colors">@item.Product?.Name</a>
                                <div class="text-[10px] lab-readout text-white/30 mt-1">@item.Product?.Category?.Name</div>
                            </div>
                        </div>

                        @* Unit price *@
                        <div class="md:col-span-2 text-center">
                            <span class="text-[10px] lab-readout text-white/40 md:hidden">Unit Price: </span>
                            <span class="lab-readout text-sm">$@item.Product?.Price.ToString("F2")</span>
                        </div>

                        @* Quantity controls *@
                        <div class="md:col-span-2 flex items-center justify-center gap-2">
                            <button class="qty-btn" @onclick="() => DecrementQuantity(item)" disabled="@(_updating || item.Quantity <= 1)">
                                <span class="material-symbols-outlined text-sm">remove</span>
                            </button>
                            <span class="lab-readout text-sm w-10 text-center font-bold">@item.Quantity</span>
                            <button class="qty-btn" @onclick="() => IncrementQuantity(item)" disabled="@(_updating || item.Quantity >= (item.Product?.Stock ?? 0))">
                                <span class="material-symbols-outlined text-sm">add</span>
                            </button>
                        </div>

                        @* Line total *@
                        <div class="md:col-span-2 text-right">
                            <span class="text-[10px] lab-readout text-white/40 md:hidden">Total: </span>
                            @{
                                var lineTotal = (item.Product?.Price ?? 0) * item.Quantity;
                            }
                            <span class="lab-readout text-lg font-bold">$@lineTotal.ToString("F2")</span>
                        </div>

                        @* Remove button *@
                        <div class="md:col-span-1 flex justify-end">
                            <button class="qty-btn hover:border-red-400 hover:text-red-400"
                                    @onclick="() => RemoveItem(item)"
                                    disabled="@_updating">
                                <span class="material-symbols-outlined text-sm">close</span>
                            </button>
                        </div>
                    </div>
                }
            </div>

            @* Cart summary *@
            <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end gap-8">
                <div class="flex gap-4">
                    <button class="border border-white/20 px-6 py-3 text-[10px] lab-readout hover:bg-white/10 transition-all disabled:opacity-30"
                            @onclick="ClearCart" disabled="@_updating">
                        Clear Cart
                    </button>
                    <a href="/catalog"
                       class="border border-white/20 px-6 py-3 text-[10px] lab-readout hover:bg-white/10 transition-all no-underline text-white">
                        Continue Shopping
                    </a>
                </div>
                <div class="data-grid-border bg-black p-8 min-w-[280px]">
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-white/10">
                        <span class="text-[10px] lab-readout text-white/40 font-bold">Items</span>
                        <span class="lab-readout text-sm">@_cartCount</span>
                    </div>
                    <div class="flex justify-between items-center mb-6">
                        <span class="text-[10px] lab-readout text-white/40 font-bold">Subtotal</span>
                        <span class="lab-readout text-2xl font-bold">$@_cartTotal.ToString("F2")</span>
                    </div>
                    <a href="/checkout"
                       class="w-full bg-white text-black px-8 py-4 text-xs lab-readout font-bold hover:bg-alert transition-colors flex items-center justify-center gap-3 no-underline">
                        <span class="material-symbols-outlined">shopping_bag</span>
                        Proceed to Checkout
                    </a>
                </div>
            </div>
        }
    </main>

    <footer class="bg-black py-12 px-6 lg:px-20 border-t border-white/10">
        <div class="flex justify-between items-center text-[8px] lab-readout text-white/20">
            <p>(C) 2024 FUTURBOL APPAREL. ALL RIGHTS RESERVED.</p>
            <a href="/" class="hover:text-alert transition-colors no-underline text-white/20">Home</a>
        </div>
    </footer>
</div>

@* Toast notification *@
@if (!string.IsNullOrEmpty(_toastMessage))
{
    <div class="toast-msg lab-readout @(_toastIsError ? "toast-error" : "toast-success")">
        @_toastMessage
    </div>
}

@code {
    private List<CartItem> _cartItems = [];
    private int _cartCount;
    private decimal _cartTotal;
    private bool _loading = true;
    private bool _updating;
    private string? _toastMessage;
    private bool _toastIsError;

    private string? _userId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrEmpty(_userId))
        {
            Nav.NavigateTo("/account/login?returnUrl=%2Fcart", forceLoad: true);
            return;
        }

        await LoadCartAsync();
    }

    private async Task LoadCartAsync()
    {
        _loading = true;
        _cartItems = await CartService.GetCartItemsAsync(_userId!);
        _cartCount = _cartItems.Sum(ci => ci.Quantity);
        _cartTotal = _cartItems.Sum(ci => (ci.Product?.Price ?? 0) * ci.Quantity);
        _loading = false;
    }

    private async Task IncrementQuantity(CartItem item)
    {
        _updating = true;
        try
        {
            await CartService.UpdateQuantityAsync(_userId!, item.ProductId, item.Quantity + 1);
            await LoadCartAsync();
        }
        catch (InvalidOperationException ex)
        {
            await ShowToast(ex.Message, true);
        }
        _updating = false;
    }

    private async Task DecrementQuantity(CartItem item)
    {
        _updating = true;
        try
        {
            await CartService.UpdateQuantityAsync(_userId!, item.ProductId, item.Quantity - 1);
            await LoadCartAsync();
        }
        catch (InvalidOperationException ex)
        {
            await ShowToast(ex.Message, true);
        }
        _updating = false;
    }

    private async Task RemoveItem(CartItem item)
    {
        _updating = true;
        await CartService.RemoveFromCartAsync(_userId!, item.ProductId);
        await LoadCartAsync();
        await ShowToast("Item removed from cart", false);
        _updating = false;
    }

    private async Task ClearCart()
    {
        _updating = true;
        await CartService.ClearCartAsync(_userId!);
        await LoadCartAsync();
        await ShowToast("Cart cleared", false);
        _updating = false;
    }

    private async Task ShowToast(string message, bool isError)
    {
        _toastMessage = message;
        _toastIsError = isError;
        StateHasChanged();
        await Task.Delay(3000);
        _toastMessage = null;
        StateHasChanged();
    }
}
