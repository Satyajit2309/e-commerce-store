@page "/orders/{Id:int}"
@attribute [Authorize]
@using EcommerceStore.Services.Interfaces
@using EcommerceStore.Models.Entities
@using EcommerceStore.Constants
@using Microsoft.AspNetCore.Authorization
@inject IOrderService OrderService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>Order #@Id | Futurbol</PageTitle>

<style type="text/tailwindcss">
    :root { --alert-color: #0df20d; }

    .futurbol-page {
        background-color: #000000;
        color: #ffffff;
        font-family: 'Space Grotesk', sans-serif;
        background-image:
            linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
        background-size: 50px 50px;
    }

    .lab-readout {
        font-family: 'Space Grotesk', monospace;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .data-grid-border {
        border: 1px solid rgba(255,255,255,0.1);
        position: relative;
    }

    .data-grid-border::before {
        content: '';
        position: absolute;
        top: -2px; left: -2px;
        width: 10px; height: 10px;
        border-top: 2px solid var(--alert-color);
        border-left: 2px solid var(--alert-color);
    }

    .data-grid-border::after {
        content: '';
        position: absolute;
        bottom: -2px; right: -2px;
        width: 10px; height: 10px;
        border-bottom: 2px solid var(--alert-color);
        border-right: 2px solid var(--alert-color);
    }

    .receipt-section {
        border: 2px solid rgba(13,242,13,0.3);
        position: relative;
    }

    .receipt-section::before {
        content: 'RECEIPT';
        position: absolute;
        top: -10px;
        left: 16px;
        background: #000;
        padding: 0 8px;
        font-size: 10px;
        font-family: 'Space Grotesk', monospace;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #0df20d;
    }

    @@media print {
        .no-print { display: none !important; }
        .futurbol-page { background-image: none; }
    }
</style>

<div class="futurbol-page min-h-screen overflow-x-hidden">
    <nav class="fixed top-0 left-0 w-full z-50 border-b border-white/20 bg-black/80 backdrop-blur-md no-print">
        <div class="flex items-center justify-between px-6 py-4">
            <div class="flex flex-col">
                <span class="text-xs text-alert lab-readout font-bold leading-none">Status: Active</span>
                <a href="/" class="text-2xl font-bold tracking-tighter uppercase no-underline text-white">Futurbol//Lab</a>
            </div>
            <div class="flex items-center gap-3">
                <a href="/catalog" class="text-[10px] lab-readout text-white/60 hover:text-alert transition-colors no-underline">Catalog</a>
                <a href="/orders" class="text-[10px] lab-readout text-white/60 hover:text-alert transition-colors no-underline">Orders</a>
                <a class="border border-white/30 px-4 py-2 text-[10px] lab-readout hover:bg-white hover:text-black transition-all no-underline text-white" href="/account/logout">Logout</a>
            </div>
        </div>
    </nav>

    <main class="pt-28 pb-20 px-6 lg:px-20">
        <div class="mb-8 no-print">
            <a href="/orders" class="text-[10px] lab-readout text-white/40 hover:text-alert transition-colors no-underline flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">arrow_back</span>Back to Orders
            </a>
        </div>

        @if (_loading)
        {
            <div class="flex items-center gap-3 text-white/40 text-sm lab-readout">
                <div class="w-2 h-2 bg-alert rounded-full animate-pulse"></div>Loading order data...
            </div>
        }
        else if (_order is null)
        {
            <div class="border border-white/10 p-12 text-center">
                <div class="text-white/30 text-sm lab-readout mb-4">Order not found.</div>
                <a href="/orders" class="border border-white/30 px-6 py-3 text-[10px] lab-readout hover:bg-white hover:text-black transition-all no-underline text-white inline-block">Back to Orders</a>
            </div>
        }
        else
        {
            <div class="mb-12">
                <div class="flex items-center gap-3 mb-3">
                    <div class="w-2 h-2 bg-alert rounded-full animate-pulse"></div>
                    <span class="text-[10px] lab-readout font-bold text-alert">Order // Detail</span>
                </div>
                <div class="flex flex-col md:flex-row md:items-center gap-4">
                    <h1 class="text-4xl md:text-5xl font-bold uppercase tracking-tighter">Order #@_order.Id.ToString("D4")</h1>
                    <span class="text-[10px] lab-readout px-3 py-1.5 border @GetStatusStyle(_order.Status) inline-block">@_order.Status</span>
                </div>
            </div>

            <div class="grid lg:grid-cols-3 gap-8 mb-12">
                @* Order info *@
                <div class="border border-white/10 bg-black/60 p-6">
                    <div class="text-[10px] lab-readout text-alert font-bold mb-4 pb-2 border-b border-white/10">Order Info</div>
                    <div class="space-y-3 text-sm">
                        <div class="flex justify-between">
                            <span class="text-white/40 text-[10px] lab-readout">Date</span>
                            <span class="lab-readout">@_order.OrderDate.ToString("dd MMM yyyy, HH:mm")</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-white/40 text-[10px] lab-readout">Status</span>
                            <span class="lab-readout">@_order.Status</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-white/40 text-[10px] lab-readout">Total</span>
                            <span class="lab-readout font-bold">$@_order.TotalAmount.ToString("F2")</span>
                        </div>
                    </div>
                </div>

                @* Shipping info *@
                <div class="border border-white/10 bg-black/60 p-6">
                    <div class="text-[10px] lab-readout text-alert font-bold mb-4 pb-2 border-b border-white/10">Shipping</div>
                    <div class="space-y-3 text-sm">
                        <div>
                            <span class="text-white/40 text-[10px] lab-readout block mb-1">Name</span>
                            <span>@_order.FullName</span>
                        </div>
                        <div>
                            <span class="text-white/40 text-[10px] lab-readout block mb-1">Address</span>
                            <span>@_order.ShippingAddress</span>
                        </div>
                        <div>
                            <span class="text-white/40 text-[10px] lab-readout block mb-1">Phone</span>
                            <span>@_order.PhoneNumber</span>
                        </div>
                    </div>
                </div>

                @* Status timeline *@
                <div class="border border-white/10 bg-black/60 p-6">
                    <div class="text-[10px] lab-readout text-alert font-bold mb-4 pb-2 border-b border-white/10">Status Timeline</div>
                    <div class="space-y-3">
                        @foreach (var status in new[] { OrderStatuses.Pending, OrderStatuses.Paid, OrderStatuses.Shipped, OrderStatuses.Delivered })
                        {
                            var isActive = IsStatusReached(_order.Status, status);
                            <div class="flex items-center gap-3">
                                <div class="w-3 h-3 rounded-full border @(isActive ? "bg-alert border-alert" : "border-white/20")"></div>
                                <span class="text-[10px] lab-readout @(isActive ? "text-alert font-bold" : "text-white/30")">@status</span>
                            </div>
                        }
                        @if (_order.Status == OrderStatuses.Cancelled)
                        {
                            <div class="flex items-center gap-3">
                                <div class="w-3 h-3 rounded-full bg-red-400 border border-red-400"></div>
                                <span class="text-[10px] lab-readout text-red-400 font-bold">Cancelled</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            @* Line items *@
            <div class="border border-white/10 bg-black/60 mb-8">
                <div class="hidden md:grid grid-cols-12 gap-4 px-8 py-4 border-b border-white/10 text-[10px] lab-readout text-white/40 font-bold">
                    <div class="col-span-5">Product</div>
                    <div class="col-span-2 text-center">Unit Price</div>
                    <div class="col-span-2 text-center">Qty</div>
                    <div class="col-span-3 text-right">Line Total</div>
                </div>
                @foreach (var item in _order.OrderItems)
                {
                    <div class="grid grid-cols-1 md:grid-cols-12 gap-4 px-8 py-5 items-center border-b border-white/5">
                        <div class="md:col-span-5">
                            <span class="text-sm font-bold uppercase">@item.Product?.Name</span>
                            <span class="text-[10px] lab-readout text-white/30 ml-2">@item.Product?.Category?.Name</span>
                        </div>
                        <div class="md:col-span-2 text-center lab-readout text-sm">$@item.UnitPrice.ToString("F2")</div>
                        <div class="md:col-span-2 text-center lab-readout text-sm">@item.Quantity</div>
                        <div class="md:col-span-3 text-right lab-readout text-sm font-bold">$@item.LineTotal.ToString("F2")</div>
                    </div>
                }
                <div class="px-8 py-5 flex justify-end">
                    <div class="flex items-center gap-8">
                        <span class="text-[10px] lab-readout text-white/40 font-bold">Order Total</span>
                        <span class="lab-readout text-2xl font-bold">$@_order.TotalAmount.ToString("F2")</span>
                    </div>
                </div>
            </div>

            @* Receipt -- visible when Delivered *@
            @if (_order.Status == OrderStatuses.Delivered)
            {
                <div class="receipt-section bg-black p-8 mt-12">
                    <div class="flex flex-col md:flex-row justify-between items-start mb-8 gap-4">
                        <div>
                            <h2 class="text-2xl font-bold uppercase tracking-tighter mb-1">Futurbol // Receipt</h2>
                            <div class="text-[10px] lab-readout text-white/40">Order delivered successfully</div>
                        </div>
                        <button class="border border-alert/40 px-4 py-2 text-[10px] lab-readout text-alert hover:bg-alert hover:text-black transition-all no-print"
                                onclick="window.print()">
                            Print Receipt
                        </button>
                    </div>

                    <div class="grid md:grid-cols-2 gap-6 mb-8 text-sm">
                        <div>
                            <div class="text-[10px] lab-readout text-white/40 mb-1">Order Number</div>
                            <div class="font-bold">#@_order.Id.ToString("D4")</div>
                        </div>
                        <div>
                            <div class="text-[10px] lab-readout text-white/40 mb-1">Order Date</div>
                            <div>@_order.OrderDate.ToString("dd MMM yyyy, HH:mm UTC")</div>
                        </div>
                        <div>
                            <div class="text-[10px] lab-readout text-white/40 mb-1">Ship To</div>
                            <div>@_order.FullName</div>
                            <div class="text-white/60">@_order.ShippingAddress</div>
                        </div>
                        <div>
                            <div class="text-[10px] lab-readout text-white/40 mb-1">Contact</div>
                            <div>@_order.PhoneNumber</div>
                        </div>
                    </div>

                    <div class="border-t border-alert/20 pt-6">
                        @foreach (var item in _order.OrderItems)
                        {
                            <div class="flex justify-between py-2 text-sm border-b border-white/5">
                                <span>@item.Product?.Name <span class="text-white/40">x@item.Quantity</span></span>
                                <span class="font-bold">$@item.LineTotal.ToString("F2")</span>
                            </div>
                        }
                        <div class="flex justify-between pt-4 mt-2">
                            <span class="text-[10px] lab-readout font-bold">Grand Total</span>
                            <span class="text-xl font-bold">$@_order.TotalAmount.ToString("F2")</span>
                        </div>
                    </div>

                    <div class="mt-8 pt-4 border-t border-white/10 text-[8px] lab-readout text-white/20 text-center">
                        Thank you for your purchase. // FUTURBOL APPAREL // Transaction Complete
                    </div>
                </div>
            }
        }
    </main>

    <footer class="bg-black py-12 px-6 lg:px-20 border-t border-white/10 no-print">
        <div class="flex justify-between items-center text-[8px] lab-readout text-white/20">
            <p>(C) 2024 FUTURBOL APPAREL. ALL RIGHTS RESERVED.</p>
            <a href="/" class="hover:text-alert transition-colors no-underline text-white/20">Home</a>
        </div>
    </footer>
</div>

@code {
    [Parameter] public int Id { get; set; }

    private Order? _order;
    private bool _loading = true;
    private string? _userId;

    protected override async Task OnParametersSetAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrEmpty(_userId))
        {
            Nav.NavigateTo("/account/login", forceLoad: true);
            return;
        }

        _loading = true;
        _order = await OrderService.GetOrderByIdAsync(Id);

        // Ensure the order belongs to this user
        if (_order is not null && _order.UserId != _userId)
        {
            _order = null;
        }

        _loading = false;
    }

    private string GetStatusStyle(string status) => status switch
    {
        OrderStatuses.Pending => "border-yellow-500/40 text-yellow-400",
        OrderStatuses.Paid => "border-blue-500/40 text-blue-400",
        OrderStatuses.Shipped => "border-purple-500/40 text-purple-400",
        OrderStatuses.Delivered => "border-alert/40 text-alert",
        OrderStatuses.Cancelled => "border-red-500/40 text-red-400",
        _ => "border-white/20 text-white/40"
    };

    private bool IsStatusReached(string currentStatus, string checkStatus)
    {
        var order = new[] { OrderStatuses.Pending, OrderStatuses.Paid, OrderStatuses.Shipped, OrderStatuses.Delivered };
        var currentIndex = Array.IndexOf(order, currentStatus);
        var checkIndex = Array.IndexOf(order, checkStatus);
        return currentIndex >= 0 && checkIndex >= 0 && currentIndex >= checkIndex;
    }
}
