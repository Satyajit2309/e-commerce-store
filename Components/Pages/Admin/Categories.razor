@page "/admin/categories"
@attribute [Authorize(Roles = EcommerceStore.Constants.Roles.Admin)]
@using EcommerceStore.Services.Interfaces
@using EcommerceStore.Models.Entities
@inject ICategoryService CategoryService
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Categories | Admin | Futurbol</PageTitle>

<style type="text/tailwindcss">
    .futurbol-admin {
        background-color: #000000;
        color: #ffffff;
        font-family: 'Space Grotesk', sans-serif;
        background-image:
            linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
        background-size: 50px 50px;
    }

    .lab-readout {
        font-family: 'Space Grotesk', monospace;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .data-grid-border {
        border: 1px solid rgba(255,255,255,0.1);
        position: relative;
    }

    .data-grid-border::before {
        content: '';
        position: absolute;
        top: -2px; left: -2px;
        width: 14px; height: 14px;
        border-top: 2px solid #0df20d;
        border-left: 2px solid #0df20d;
    }

    .data-grid-border::after {
        content: '';
        position: absolute;
        bottom: -2px; right: -2px;
        width: 14px; height: 14px;
        border-bottom: 2px solid #0df20d;
        border-right: 2px solid #0df20d;
    }

    .futurbol-input {
        background: transparent;
        border: 1px solid rgba(255,255,255,0.15);
        color: #fff;
        width: 100%;
        outline: none;
    }

    .futurbol-input:focus { border-color: rgba(13,242,13,0.5); }

    .futurbol-textarea {
        background: transparent;
        border: 1px solid rgba(255,255,255,0.15);
        color: #fff;
        width: 100%;
        resize: vertical;
        outline: none;
    }

    .futurbol-textarea:focus { border-color: rgba(13,242,13,0.5); }

    .field-label {
        display: block;
        font-size: 10px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.4);
        margin-bottom: 6px;
        font-family: 'Space Grotesk', monospace;
    }

    .table-row:hover { background: rgba(255,255,255,0.02); }
</style>

<div class="futurbol-admin min-h-screen px-6 lg:px-20 py-16">
    @* Header *@
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-12 gap-6">
        <div>
            <div class="flex items-center gap-3 mb-3">
                <div class="w-2 h-2 bg-alert rounded-full animate-pulse"></div>
                <span class="text-[10px] lab-readout font-bold text-alert">Admin // Category Registry</span>
            </div>
            <h1 class="text-4xl md:text-5xl font-bold uppercase tracking-tighter">Categories</h1>
        </div>
        <div class="flex items-center gap-3">
            <a href="/admin" class="border border-white/30 px-4 py-2 text-[10px] lab-readout hover:bg-white hover:text-black transition-all no-underline text-white">Dashboard</a>
            <a href="/admin/products" class="border border-white/30 px-4 py-2 text-[10px] lab-readout hover:bg-white hover:text-black transition-all no-underline text-white">Products</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="border border-@(_isError ? "red-500/40" : "alert/40") px-6 py-4 mb-6 text-[10px] lab-readout @(_isError ? "text-red-400" : "text-alert") flex items-center gap-3">
            <span class="material-symbols-outlined text-sm">@(_isError ? "error" : "check_circle")</span>
            @_message
        </div>
    }

    <div class="grid lg:grid-cols-2 gap-12">
        @* Category list *@
        <div>
            <div class="flex items-center gap-3 mb-6">
                <span class="text-[10px] lab-readout font-bold text-white/40">Registry Entries</span>
                <span class="text-[8px] lab-readout text-alert">@_categories.Count total</span>
            </div>

            @if (_loading)
            {
                <div class="flex items-center gap-3 text-white/40 text-sm lab-readout">
                    <div class="w-2 h-2 bg-alert rounded-full animate-pulse"></div>Loading...
                </div>
            }
            else if (!_categories.Any())
            {
                <div class="border border-white/10 p-8 text-center">
                    <div class="text-white/30 text-sm lab-readout">No categories yet.</div>
                </div>
            }
            else
            {
                <div class="data-grid-border bg-black/60">
                    @foreach (var (cat, i) in _categories.Select((c, i) => (c, i)))
                    {
                        <div class="table-row @(i < _categories.Count - 1 ? "border-b border-white/5" : "") transition-colors">
                            @if (_editingId == cat.Id)
                            {
                                <div class="p-4">
                                    <input class="futurbol-input px-3 py-2 text-sm mb-2"
                                           value="@_editName"
                                           @oninput="e => _editName = e.Value?.ToString() ?? string.Empty"
                                           placeholder="Category name" />
                                    <textarea class="futurbol-textarea px-3 py-2 text-sm mb-3" rows="2"
                                              value="@_editDesc"
                                              @oninput="e => _editDesc = e.Value?.ToString() ?? string.Empty"
                                              placeholder="Description"></textarea>
                                    <div class="flex gap-2">
                                        <button @onclick="SaveEdit"
                                                class="border border-alert/40 px-4 py-2 text-[10px] lab-readout text-alert hover:bg-alert hover:text-black transition-all">
                                            Save
                                        </button>
                                        <button @onclick="CancelEdit"
                                                class="border border-white/30 px-4 py-2 text-[10px] lab-readout hover:bg-white/10 transition-all">
                                            Cancel
                                        </button>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="flex items-center justify-between px-6 py-4">
                                    <div>
                                        <div class="font-bold text-sm uppercase">@cat.Name</div>
                                        @if (!string.IsNullOrWhiteSpace(cat.Description))
                                        {
                                            <div class="text-[10px] text-white/40 mt-1">@cat.Description</div>
                                        }
                                        <div class="text-[8px] lab-readout text-alert mt-1">@(cat.Products?.Count ?? 0) product(s)</div>
                                    </div>
                                    <div class="flex items-center gap-2 shrink-0">
                                        <button @onclick="() => StartEdit(cat)"
                                                class="border border-white/30 px-3 py-2 text-[10px] lab-readout hover:bg-white hover:text-black transition-all">
                                            Edit
                                        </button>
                                        @if (cat.Products?.Count == 0)
                                        {
                                            <button @onclick="() => ConfirmDelete(cat)"
                                                    class="border border-red-500/30 px-3 py-2 text-[10px] lab-readout text-red-400 hover:bg-red-500 hover:text-white transition-all">
                                                Delete
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="text-[8px] lab-readout text-white/20 px-3 py-2">Has products</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        @* Add category form *@
        <div>
            <div class="flex items-center gap-3 mb-6">
                <span class="text-[10px] lab-readout font-bold text-white/40">New Entry</span>
            </div>
            <div class="data-grid-border bg-black/60 p-6">
                <EditForm Model="_newForm" OnValidSubmit="HandleAddCategory">
                    <DataAnnotationsValidator />
                    <div class="space-y-4">
                        <div>
                            <label class="field-label">Category Name *</label>
                            <InputText class="futurbol-input px-4 py-3 text-sm" @bind-Value="_newForm.Name" placeholder="e.g. Limited Edition" />
                            <ValidationMessage For="() => _newForm.Name" class="text-[10px] text-red-400 mt-1 lab-readout block" />
                        </div>
                        <div>
                            <label class="field-label">Description</label>
                            <InputTextArea class="futurbol-textarea px-4 py-3 text-sm" rows="2" @bind-Value="_newForm.Description" placeholder="Optional description..." />
                        </div>
                        <button type="submit"
                                disabled="@_addSubmitting"
                                class="w-full bg-white text-black px-6 py-3 text-sm lab-readout font-bold hover:bg-alert transition-colors disabled:opacity-40 disabled:cursor-not-allowed flex items-center justify-center gap-3">
                            @if (_addSubmitting)
                            {
                                <div class="w-4 h-4 border-2 border-black border-t-transparent rounded-full animate-spin"></div>
                            }
                            Add Category
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>

    @* Delete confirmation modal *@
    @if (_deleteTarget is not null)
    {
        <div class="fixed inset-0 bg-black/80 backdrop-blur-sm z-50 flex items-center justify-center px-6">
            <div class="data-grid-border bg-black p-8 max-w-md w-full">
                <div class="flex items-center gap-3 mb-4">
                    <span class="material-symbols-outlined text-red-400">warning</span>
                    <span class="text-xs lab-readout font-bold">Confirm Delete</span>
                </div>
                <p class="text-white/60 text-sm mb-8">
                    Delete category <span class="text-white font-bold">"@_deleteTarget.Name"</span>? This cannot be undone.
                </p>
                <div class="flex gap-4">
                    <button @onclick="ExecuteDelete"
                            class="flex-1 bg-red-500 text-white px-6 py-3 text-[10px] lab-readout font-bold hover:bg-red-600 transition-colors">
                        Confirm Delete
                    </button>
                    <button @onclick="() => _deleteTarget = null"
                            class="flex-1 border border-white/30 px-6 py-3 text-[10px] lab-readout hover:bg-white hover:text-black transition-all">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Category>    _categories   = [];
    private CategoryFormModel _newForm      = new();
    private Category?         _deleteTarget = null;
    private int?              _editingId    = null;
    private string            _editName     = string.Empty;
    private string            _editDesc     = string.Empty;
    private bool              _loading      = true;
    private bool              _addSubmitting = false;
    private string            _message      = string.Empty;
    private bool              _isError      = false;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading    = true;
        _categories = await CategoryService.GetCategoriesAsync();
        // load product counts
        foreach (var cat in _categories)
        {
            var full = await CategoryService.GetCategoryByIdAsync(cat.Id);
            cat.Products = full?.Products ?? new List<Product>();
        }
        _loading = false;
    }

    private async Task HandleAddCategory()
    {
        _addSubmitting = true;
        _message       = string.Empty;
        try
        {
            await CategoryService.CreateCategoryAsync(new Category
            {
                Name        = _newForm.Name,
                Description = _newForm.Description
            });
            _newForm  = new CategoryFormModel();
            _message  = "Category added successfully.";
            _isError  = false;
            await LoadAsync();
        }
        catch
        {
            _message = "Failed to add category. Name may already exist.";
            _isError = true;
        }
        finally
        {
            _addSubmitting = false;
        }
    }

    private void StartEdit(Category cat)
    {
        _editingId = cat.Id;
        _editName  = cat.Name;
        _editDesc  = cat.Description ?? string.Empty;
        _message   = string.Empty;
    }

    private void CancelEdit() => _editingId = null;

    private async Task SaveEdit()
    {
        if (_editingId is null) return;
        if (string.IsNullOrWhiteSpace(_editName))
        {
            _message = "Category name cannot be empty.";
            _isError = true;
            return;
        }

        try
        {
            await CategoryService.UpdateCategoryAsync(new Category
            {
                Id          = _editingId.Value,
                Name        = _editName,
                Description = string.IsNullOrWhiteSpace(_editDesc) ? null : _editDesc
            });
            _message   = "Category updated.";
            _isError   = false;
            _editingId = null;
            await LoadAsync();
        }
        catch
        {
            _message = "Failed to update category. Name may already be taken.";
            _isError = true;
        }
    }

    private void ConfirmDelete(Category cat) => _deleteTarget = cat;

    private async Task ExecuteDelete()
    {
        if (_deleteTarget is null) return;
        var success = await CategoryService.DeleteCategoryAsync(_deleteTarget.Id);
        _message      = success ? $"Category \"{_deleteTarget.Name}\" deleted." : "Cannot delete a category that has products.";
        _isError      = !success;
        _deleteTarget = null;
        await LoadAsync();
    }

    private class CategoryFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Name is required.")]
        [System.ComponentModel.DataAnnotations.StringLength(100)]
        public string Name { get; set; } = string.Empty;

        public string? Description { get; set; }
    }
}
