@page "/"
@using EcommerceStore.Services.Interfaces
@inject ICartService CartService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Futurbol | Football Jersey Store</PageTitle>

<style type="text/tailwindcss">
    :root {
        --alert-color: #0df20d;
    }

    .futurbol-page {
        background-color: #000000;
        color: #ffffff;
        font-family: 'Space Grotesk', sans-serif;
        background-image:
            linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
        background-size: 50px 50px;
    }

    .data-grid-border {
        border: 1px solid rgba(255, 255, 255, 0.1);
        position: relative;
    }

    .data-grid-border::before {
        content: '';
        position: absolute;
        top: -2px;
        left: -2px;
        width: 10px;
        height: 10px;
        border-top: 2px solid var(--alert-color);
        border-left: 2px solid var(--alert-color);
    }

    .scanline {
        width: 100%;
        height: 1px;
        background: var(--alert-color);
        position: absolute;
        top: 0;
        left: 0;
        opacity: 0.3;
        pointer-events: none;
        z-index: 10;
    }

    .lab-readout {
        font-family: 'Space Grotesk', monospace;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .deconstructed-frame {
        position: relative;
        padding: 2rem;
        border-left: 1px solid white;
        border-bottom: 1px solid white;
    }

    .futurbol-page ::-webkit-scrollbar {
        width: 4px;
    }

    .futurbol-page ::-webkit-scrollbar-track {
        background: #000;
    }

    .futurbol-page ::-webkit-scrollbar-thumb {
        background: #fff;
    }
</style>

<div class="futurbol-page overflow-x-hidden selection:bg-alert selection:text-black">
    <nav class="fixed top-0 left-0 w-full z-50 border-b border-white/20 bg-black/80 backdrop-blur-md">
        <div class="flex items-center justify-between px-6 py-4">
            <div class="flex items-center gap-4">
                <div class="flex flex-col">
                    <span class="text-xs text-alert lab-readout font-bold leading-none">Status: Active</span>
                    <span class="text-2xl font-bold tracking-tighter uppercase">Futurbol//Lab</span>
                </div>
            </div>
            <div class="hidden lg:flex gap-12 text-[10px] lab-readout font-bold">
                <a class="hover:text-alert transition-colors flex items-center gap-2" href="/catalog"><span class="w-1 h-1 bg-white"></span>New Arrivals</a>
                <a class="hover:text-alert transition-colors flex items-center gap-2" href="/catalog"><span class="w-1 h-1 bg-white"></span>Clubs</a>
                <a class="hover:text-alert transition-colors flex items-center gap-2" href="/catalog"><span class="w-1 h-1 bg-white"></span>National Teams</a>
                <a class="hover:text-alert transition-colors flex items-center gap-2" href="#"><span class="w-1 h-1 bg-white"></span>Customizer</a>
            </div>
            <div class="flex items-center gap-3">
                <AuthorizeView>
                    <Authorized Context="authState">
                        <a class="border border-white/30 px-4 py-2 text-[10px] lab-readout hover:bg-white hover:text-black transition-all" href="/account/logout">
                            Logout
                        </a>
                        <AuthorizeView Roles="@Roles.Admin" Context="adminAuthState">
                            <a class="border border-alert/40 px-4 py-2 text-[10px] lab-readout text-alert hover:bg-alert hover:text-black transition-all" href="/admin">
                                Admin
                            </a>
                        </AuthorizeView>
                    </Authorized>
                    <NotAuthorized>
                        <a class="border border-white/30 px-4 py-2 text-[10px] lab-readout hover:bg-white hover:text-black transition-all" href="/account/login">
                            Login
                        </a>
                        <a class="border border-alert/40 px-4 py-2 text-[10px] lab-readout text-alert hover:bg-alert hover:text-black transition-all" href="/account/register">
                            Register
                        </a>
                    </NotAuthorized>
                </AuthorizeView>
                <a href="/cart" class="border border-white/30 px-4 py-2 text-[10px] lab-readout hover:bg-white hover:text-black transition-all no-underline text-white">
                    Cart (@_cartCount)
                </a>
            </div>
        </div>
    </nav>

    <main class="min-h-screen pt-32 pb-20 px-6 lg:px-20 grid lg:grid-cols-12 gap-8">
